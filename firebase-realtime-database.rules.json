{
  "rules": {
    ".read": false,
    ".write": false,
    "finances": {
      "users": {
        "$uid": {
          ".read": "auth != null && auth.uid === $uid",
          ".write": "auth != null && auth.uid === $uid"
        }
      }
    },
    "userProfiles": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "emailDirectory": {
      "$emailKey": {
        ".read": "auth != null",
        ".write": "auth != null && ((!data.exists() && newData.child('uid').val() === auth.uid) || data.child('uid').val() === auth.uid)"
      }
    },
    "sharedLoans": {
      "$loanId": {
        ".read": "auth != null && (data.child('lenderUid').val() === auth.uid || data.child('borrowerUid').val() === auth.uid)",
        ".write": "auth != null && ((!data.exists() && newData.child('lenderUid').val() === auth.uid) || data.child('lenderUid').val() === auth.uid)"
      }
    },
    "userSharedLoans": {
      "$uid": {
        "$loanId": {
          ".read": "auth != null && auth.uid === $uid",
          ".write": "auth != null && (auth.uid === $uid || root.child('sharedLoans').child($loanId).child('lenderUid').val() === auth.uid)"
        }
      }
    }
  }
}
